  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// 1. Define the login request details\r",
          "const loginRequest = {\r",
          "    url: pm.variables.replaceIn('{{baseUrl}}/api/auth/login'), // Replace with your login URL\r",
          "    method: 'POST',\r",
          "    header: {\r",
          "        'Content-Type': 'application/json'\r",
          "    },\r",
          "    body: {\r",
          "        mode: 'raw',\r",
          "        raw: JSON.stringify({\r",
          "            \"email\": pm.variables.replaceIn('{{username}}'),\r",
          "            \"password\": pm.variables.replaceIn('{{password}}')  // Replace with your actual password\r",
          "        })\r",
          "    }\r",
          "};\r",
          "\r",
          "// 2. Execute the login request\r",
          "pm.sendRequest(loginRequest, (err, response) => {\r",
          "    if (err) {\r",
          "        console.error(\"Login request failed:\", err);\r",
          "    } else {\r",
          "        const responseJson = response.json();\r",
          "        \r",
          "        // 3. Extract the token (Ensure \"token\" matches your API's key name)\r",
          "        const token = responseJson.token || responseJson.access_token;\r",
          "\r",
          "        if (token) {\r",
          "            pm.collectionVariables.set(\"token\", token);\r",
          "            console.log(\"Token successfully refreshed and saved!\");\r",
          "        } else {\r",
          "            console.error(\"Token not found in login response. Check the Postman Console (Ctrl+Alt+C).\");\r",
          "        }\r",
          "    }\r",
          "});\r",
          ""
        ]
      }
    },
